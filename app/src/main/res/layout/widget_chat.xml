<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="12dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="8dp">

        <ImageView
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/orb"
            android:layout_marginEnd="8dp"
            android:contentDescription="@string/app_name" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/app_name"
            android:textColor="@color/text"
            android:textSize="15sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/widget_settings"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:padding="4dp"
            android:src="@android:drawable/ic_menu_manage"
            android:contentDescription="@string/settings" />
    </LinearLayout>

    <!-- Seneste bruger-besked (lille, dæmpet) -->
    <TextView
        android:id="@+id/widget_last_user"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/text_dim"
        android:textSize="12sp"
        android:maxLines="2"
        android:ellipsize="end"
        android:paddingBottom="4dp"
        android:visibility="gone" />

    <!-- Seneste Claude-svar (fylder resten) -->
    <TextView
        android:id="@+id/widget_last_reply"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:textColor="@color/text"
        android:textSize="14sp"
        android:ellipsize="end"
        android:text="@string/empty_hint" />

    <!-- Input-bjælke (tryk for at skrive) -->
    <LinearLayout
        android:id="@+id/widget_input_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/input_bar"
        android:padding="12dp"
        android:layout_marginTop="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/write_message"
            android:textColor="@color/text_dim"
            android:textSize="13sp" />

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/ic_menu_send"
            android:contentDescription="@string/send" />
    </LinearLayout>

</LinearLayout>
