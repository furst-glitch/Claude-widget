<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/text"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginTop="20dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_intro"
            android:textColor="@color/text_dim"
            android:textSize="13sp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="28dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/model"
            android:textColor="@color/text_dim"
            android:textSize="12sp"
            android:layout_marginBottom="6dp" />

        <Spinner
            android:id="@+id/settings_model"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/input_bar"
            android:padding="12dp"
            android:layout_marginBottom="20dp" />

        <Button
            android:id="@+id/settings_save"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/save"
            android:textColor="@color/bg_dark"
            android:textStyle="bold"
            android:background="@drawable/button_accent"
            android:layout_marginTop="8dp"
            android:padding="14dp" />

        <Button
            android:id="@+id/settings_clear"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/clear_chat"
            android:textColor="@color/text_dim"
            android:background="@android:color/transparent"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/get_key_hint"
            android:textColor="@color/text_dim"
            android:textSize="11sp"
            android:layout_marginTop="28dp"
            android:lineSpacingExtra="3dp" />

    </LinearLayout>
</ScrollView>
